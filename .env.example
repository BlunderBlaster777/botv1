# ══════════════════════════════════════════════════════════════════════════════
# botv1 – Liquidity Sniper Bot  ·  Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE THIS FILE
# ─────────────────────
# 1. Copy this file to a new file called  .env  in the same directory:
#
#       cp .env.example .env
#
# 2. Open .env and replace every placeholder (ALL_CAPS values like
#    YOUR_PROJECT_ID) with your real values.  The sections below walk
#    you through each variable.
#
# 3. Make sure .env is listed in .gitignore so it is NEVER committed.
#    (It already is by default in this project.)
#
# 4. Run the bot:
#
#       python -m src.bot
#
# ══════════════════════════════════════════════════════════════════════════════

# ── STEP 1 · Choose your network ─────────────────────────────────────────────
#
# Supported values:  ethereum | polygon | base | arbitrum
#
# Leave this as "ethereum" if you are unsure.  Changing this one value
# automatically loads the correct DEX contract addresses and wrapped-token
# address for that chain, so you do NOT need to edit the address section
# below unless you want to override a specific address.
#
NETWORK=ethereum

# ── STEP 2 · JSON-RPC endpoint ────────────────────────────────────────────────
#
# The bot talks to the blockchain through an RPC node.  You can use a
# free hosted service (Infura or Alchemy) or run your own node.
#
# How to get a free RPC URL:
#   • Infura  → https://app.infura.io/  → create a project → copy the HTTPS URL
#   • Alchemy → https://www.alchemy.com/ → create an app → copy the HTTPS URL
#
# Examples (replace YOUR_PROJECT_ID / YOUR_API_KEY with your real key):
#
#   Ethereum mainnet (Infura)  : https://mainnet.infura.io/v3/YOUR_PROJECT_ID
#   Ethereum mainnet (Alchemy) : https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#
#   Polygon PoS (Infura)       : https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID
#   Polygon PoS (Alchemy)      : https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#
#   Base (Alchemy)             : https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   Base (public, no key)      : https://mainnet.base.org
#
#   Arbitrum One (Infura)      : https://arbitrum-mainnet.infura.io/v3/YOUR_PROJECT_ID
#   Arbitrum One (Alchemy)     : https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#
RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# ── STEP 3 · Bot wallet private key ───────────────────────────────────────────
#
# This is the private key of the wallet the bot will use to sign and send
# transactions.  It must start with  0x  followed by 64 hex characters.
#
# HOW TO CREATE A DEDICATED BOT WALLET
# ──────────────────────────────────────
# Use MetaMask, Rabby, or any Ethereum wallet app to create a brand-new
# account.  Export its private key from the wallet settings and paste it
# below.  NEVER use your main / personal wallet here.
#
# HOW MUCH TO FUND THE WALLET
# ─────────────────────────────
# The wallet needs enough native tokens to:
#   • Pay gas fees for every transaction (buy + sell + approvals).
#   • Cover the trade amounts (MAX_TRADE_ETH below).
#
# Recommended starting balances:
#   Ethereum  →   1 ETH   (gas is expensive; trades can be up to MAX_TRADE_ETH)
#   Polygon   → 500 MATIC (gas is cheap; but MATIC value is lower)
#   Base      → 0.5 ETH   (L2 gas is cheap)
#   Arbitrum  → 0.5 ETH   (L2 gas is cheap)
#
# ⚠️  SECURITY WARNING
# ─────────────────────
# • NEVER commit this file to git.
# • NEVER share your private key with anyone.
# • Keep only the minimum funds you need in this wallet.
# • Revoke token approvals when not in use.
#
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── STEP 4 · Strategy parameters ──────────────────────────────────────────────
#
# Minimum net profit in the network's native token (after gas) required before
# the bot executes a trade.  Lower values mean more trades but higher risk of
# losses if the price moves before the second leg executes.
#
# Recommended starting value: 0.005 (≈ $15 at $3 000/ETH)
#
MIN_PROFIT_ETH=0.005

# Maximum amount of the native token (or its wrapped equivalent) to spend on
# a single trade leg.  Larger amounts capture more profit but increase exposure.
#
# Recommended starting value: 0.1 ETH / 500 MATIC
#
MAX_TRADE_ETH=0.1

# Slippage tolerance as a decimal fraction.
#   0.005 = 0.5 %  (recommended – tight but realistic for liquid pools)
#   0.01  = 1 %    (more lenient – use on less liquid chains)
#
SLIPPAGE_TOLERANCE=0.005

# Maximum gas price (in Gwei) the bot is willing to pay.
# Trades are skipped when the network gas price exceeds this cap.
#
# Recommended values:
#   Ethereum : 100 Gwei  (adjust during periods of high congestion)
#   Polygon  : 200 Gwei
#   Base     :  5 Gwei
#   Arbitrum :  2 Gwei
#
MAX_GAS_PRICE_GWEI=100

# How often (in seconds) to re-scan pools for opportunities.
# Lower = faster reaction but more RPC calls (watch your API rate limits).
#
POLL_INTERVAL_SECONDS=5

# ── STEP 5 · Token pairs to monitor ──────────────────────────────────────────
#
# Comma-separated list of ERC-20 token addresses to watch.
# The bot pairs each token against the wrapped native token (WETH / WMATIC)
# and scans all configured pools.
#
# You can leave this blank to use the built-in defaults for the selected
# NETWORK, or specify your own list of addresses.
#
# Default token addresses per network:
#
#   ETHEREUM  (WETH / USDC / DAI)
#     0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2  ← WETH
#     0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48  ← USDC
#     0x6B175474E89094C44Da98b954EedeAC495271d0F  ← DAI
#
#   POLYGON  (WMATIC / USDC / USDT)
#     0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270  ← WMATIC
#     0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174  ← USDC (PoS)
#     0xc2132D05D31c914a87C6611C10748AEb04B58e8F  ← USDT (PoS)
#
#   BASE  (WETH / USDbC / DAI)
#     0x4200000000000000000000000000000000000006  ← WETH
#     0xd9aAEc86B65D86f6A7B5B1b0c42FFA531710b6CA  ← USDbC (bridged USDC)
#     0x50c5725949A6F0c72E6C4a641F24049A917DB0Cb  ← DAI
#
#   ARBITRUM  (WETH / USDC / USDT)
#     0x82aF49447D8a07e3bd95BD0d56f35241523fBab1  ← WETH
#     0xaf88d065e77c8cC2239327C5EDb3A432268e5831  ← USDC (native)
#     0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9  ← USDT
#
# Uncomment and edit one of the blocks below (or leave blank for defaults):
#
# WATCHED_TOKENS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0x6B175474E89094C44Da98b954EedeAC495271d0F

# ── STEP 6 · DEX contract addresses (optional overrides) ──────────────────────
#
# Leave ALL of these commented out to use the built-in defaults for your
# chosen NETWORK.  Only uncomment and edit them if you need to point the bot
# at a different DEX deployment (e.g. a testnet fork or a new V3 deployment).
#
# ── Ethereum mainnet defaults ──────────────────────────────────────────
# UNISWAP_V2_FACTORY=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f
# UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
