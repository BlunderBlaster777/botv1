# WETH_ADDRESS=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
#
# ── Base defaults (BaseSwap V2 + Uniswap V3) ──────────────────────────
# UNISWAP_V2_FACTORY=0xFDa619b6d20975be80A10332cD39b9a4b0FAa8BB
